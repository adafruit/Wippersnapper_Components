{
    "title": "Display Component Definition",
    "description": "A Display WipperSnapper component type for use in Adafruit IO",
    "type": "object",
    "required": [
        "displayName",
        "displayType",
        "vendor"
    ],
    "additionalProperties": false,
    "properties": {
        "displayName": {
            "description": "The human-friendly name of this component.",
            "type": "string",
            "minLength": 3,
            "maxLength": 30
        },
        "published": {
            "description": "If true, this component is supported by the current firmware version and will be displayed to all users. If false, it is hidden behind a developer toggle so that contributors can still work on it against the production site.",
            "type": "boolean"
        },
        "description": {
            "description": "A brief description describing this component's capabilities.",
            "type": "string",
            "minLength": 3,
            "maxLength": 255
        },
        "productURL": {
            "description": "Link to this component's homepage.",
            "type": "string",
            "format": "uri"
        },
        "documentationURL": {
            "description": "Link to this component's documentation.",
            "type": "string",
            "format": "uri"
        },
        "vendor": {
            "description": "Name of the company that makes this component.",
            "type": "string",
            "minLength": 3,
            "maxLength": 24
        },
        "displayType": {
            "description": "Display configuration and type, maps to ws.display.Add",
            "type": "object",
            "required": [
                "type",
                "driver"
            ],
            "properties": {
                "type": {
                    "description": "The class of display (maps to DisplayClass enum)",
                    "type": "string",
                    "enum": [
                        "unspecified",
                        "epd",
                        "tft",
                        "oled",
                        "led_backpack",
                        "char_lcd"
                    ]
                },
                "driver": {
                    "description": "Driver chip name string (e.g. \"SSD1680\", \"ST7789\", \"SSD1306\", \"HT16K33\")",
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 32
                },
                "panel": {
                    "description": "Panel identifier for same-driver disambiguation. Format: \"{size}-{WxH}-{mode}\" or \"adafruit-{product_id}\"",
                    "type": "string",
                    "maxLength": 32
                },
                "spiEpd": {
                    "description": "SPI configuration for EPD displays.",
                    "type": "object",
                    "properties": {
                        "bus": {
                            "type": "integer"
                        }
                    }
                },
                "spiTft": {
                    "description": "SPI configuration for TFT displays.",
                    "type": "object",
                    "properties": {
                        "bus": {
                            "type": "integer"
                        }
                    }
                },
                "i2c": {
                    "description": "I2C configuration for OLED/LED backpack/Character LCD displays.",
                    "type": "object",
                    "properties": {
                        "addresses": {
                            "description": "List of supported I2C addresses for this device (hex strings, e.g. [\"0x3C\", \"0x3D\"]). First entry is the default.",
                            "type": "array",
                            "items": {
                                "type": "string",
                                "pattern": "^0x[0-9A-Fa-f]{2}$"
                            }
                        }
                    }
                },
                "epdConfig": {
                    "description": "Configuration for EPD displays",
                    "type": "object",
                    "required": [
                        "mode",
                        "width",
                        "height",
                        "textSize"
                    ],
                    "properties": {
                        "mode": {
                            "type": "string",
                            "enum": [
                                "unspecified",
                                "grayscale4",
                                "mono"
                            ]
                        },
                        "width": {
                            "description": "Width of the EPD display, in pixels",
                            "type": "integer",
                            "minimum": 1
                        },
                        "height": {
                            "description": "Height of the EPD display, in pixels",
                            "type": "integer",
                            "minimum": 1
                        },
                        "textSize": {
                            "type": "integer",
                            "description": "The default text size for the display (Scale of 8x5 px font)"
                        }
                    }
                },
                "tftConfig": {
                    "description": "Configuration for TFT displays",
                    "type": "object",
                    "required": [
                        "width",
                        "height",
                        "rotation",
                        "textSize"
                    ],
                    "properties": {
                        "width": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "height": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "rotation": {
                            "type": "integer",
                            "enum": [0, 1, 2, 3]
                        },
                        "textSize": {
                            "type": "integer",
                            "description": "The default text size for the display (Scale of 8x5 px font)"
                        }
                    }
                },
                "displayConfig": {
                    "description": "Generic display properties (for OLED and other pixel displays)",
                    "type": "object",
                    "required": [
                        "width",
                        "height",
                        "textSize"
                    ],
                    "properties": {
                        "width": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "height": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "rotation": {
                            "type": "integer",
                            "enum": [0, 1, 2, 3]
                        },
                        "textSize": {
                            "type": "integer",
                            "description": "The default text size for the display (Scale of 8x5 px font)"
                        }
                    }
                },
                "ledBackpackConfig": {
                    "description": "Configuration for LED backpack displays (HT16K33-based)",
                    "type": "object",
                    "properties": {
                        "brightness": {
                            "description": "Brightness level 0 (off) to 15 (full)",
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 15
                        },
                        "alignment": {
                            "description": "Text alignment",
                            "type": "string",
                            "enum": ["left", "right"]
                        }
                    }
                },
                "charLcdConfig": {
                    "description": "Configuration for character LCD displays",
                    "type": "object",
                    "required": [
                        "rows",
                        "columns"
                    ],
                    "properties": {
                        "rows": {
                            "description": "Number of text rows",
                            "type": "integer",
                            "minimum": 1
                        },
                        "columns": {
                            "description": "Number of text columns",
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                }
            }
        }
    }
}